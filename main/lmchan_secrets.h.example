/*
 * lmchan Build-time Secrets
 *
 * This is the ONLY way to configure lmchan.
 * Copy this file to lmchan_secrets.h and fill in your values.
 * After any change, rebuild: idf.py fullclean && idf.py build
 *
 *   cp lmchan_secrets.h.example lmchan_secrets.h
 */

#pragma once

/* WiFi */
#define LMCHAN_SECRET_WIFI_SSID       ""
#define LMCHAN_SECRET_WIFI_PASS       ""

/* Telegram Bot */
#define LMCHAN_SECRET_TG_TOKEN        ""
#define LMCHAN_SECRET_TG_ALLOWLIST    ""  /* comma-separated Telegram user IDs, empty means allow all */

/* Feishu App (long connection) */
#define LMCHAN_SECRET_FS_APP_ID       ""
#define LMCHAN_SECRET_FS_APP_SECRET   ""
#define LMCHAN_SECRET_FS_WS_URL       "https://open.feishu.cn/callback/ws/endpoint"
#define LMCHAN_SECRET_FS_GROUP_MODE   "mention"  /* mention | all */

/* LLM */
#define LMCHAN_SECRET_API_KEY         ""
#define LMCHAN_SECRET_MODEL           ""
#define LMCHAN_SECRET_MODEL_PROVIDER  "anthropic"   /* anthropic | openai | openai_compatible */
#define LMCHAN_SECRET_API_BASE_URL    ""            /* e.g. https://api.openrouter.ai (for openai_compatible) */
#define LMCHAN_SECRET_API_PATH        "/v1/chat/completions"

/* HTTP Proxy (leave empty or set both) */
#define LMCHAN_SECRET_PROXY_HOST      ""
#define LMCHAN_SECRET_PROXY_PORT      ""
#define LMCHAN_SECRET_PROXY_TYPE      ""   /* "http" or "socks5" */

/* Brave Search API */
#define LMCHAN_SECRET_SEARCH_KEY      ""
